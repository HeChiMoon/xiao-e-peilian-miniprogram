.role-page {
  padding-top: 18rpx;
}

.role-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 24rpx 22rpx;
  text-align: center;
}

.role-mascot {
  width: 136rpx;
  height: 136rpx;
  border: 8rpx solid #FFF0E8;
  border-radius: 50%;
  background: #F4A882;
  box-shadow: 0 16rpx 40rpx rgba(244, 168, 130, 0.26);
}

.role-kicker,
.role-title,
.role-copy {
  display: block;
}

.role-kicker {
  margin-top: 14rpx;
  color: #F4A882;
  font-size: 28rpx;
  font-weight: 900;
}

.role-title {
  margin-top: 8rpx;
  color: #3F3F3F;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.18;
}

.role-copy {
  max-width: 560rpx;
  margin-top: 12rpx;
  color: #6B6B6B;
  font-size: 28rpx;
  line-height: 1.55;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.resume-card {
  margin: 0 0 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #fff7f1;
  box-shadow: 0 8rpx 24rpx rgba(220, 215, 205, 0.45);
}

.resume-title,
.resume-copy {
  display: block;
}

.resume-title {
  color: #3f3f3f;
  font-size: 30rpx;
  font-weight: 900;
}

.resume-copy {
  margin-top: 8rpx;
  color: #6b6b6b;
  font-size: 25rpx;
  line-height: 1.5;
}

.role-card {
  min-height: 140rpx;
  display: grid;
  grid-template-columns: 88rpx 1fr;
  gap: 18rpx;
  align-items: center;
  padding: 20rpx 22rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(220, 215, 205, 0.62);
  text-align: left;
}

.role-card.elder {
  background: #FFF7F1;
}

.role-card.caregiver {
  background: #F0F9F4;
}

.role-card.admin {
  background: #F5F4EF;
}

.role-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.role-content {
  min-width: 0;
}

.role-name,
.role-desc,
.role-action {
  display: block;
}

.role-name {
  color: #3F3F3F;
  font-size: 32rpx;
  font-weight: 900;
}

.role-desc {
  margin-top: 6rpx;
  color: #6B6B6B;
  font-size: 25rpx;
  line-height: 1.45;
}

.role-action {
  margin-top: 8rpx;
  color: #C66F3C;
  font-size: 26rpx;
  font-weight: 900;
}
