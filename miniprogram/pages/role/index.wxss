.role-page {
  padding-top: 18rpx;
}

.role-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 42rpx 34rpx 36rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(180deg, #ffffff, #fcfaf6);
}

.role-art {
  position: relative;
  width: 150rpx;
  height: 150rpx;
}

.role-art-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
}

.role-art-ring-outer {
  background: rgba(240, 161, 116, 0.12);
  transform: scale(1.08);
}

.role-art-ring-inner {
  background: linear-gradient(180deg, #ffe5d4, #fff6ef);
}

.role-mascot {
  position: absolute;
  inset: 14rpx;
  width: 122rpx;
  height: 122rpx;
  border-radius: 50%;
}

.role-kicker,
.role-title,
.role-copy,
.resume-title,
.resume-copy,
.role-name,
.role-desc,
.role-action,
.role-chip {
  display: block;
}

.role-kicker {
  margin-top: 18rpx;
  color: #e29063;
  font-size: 26rpx;
  font-weight: 700;
}

.role-title {
  margin-top: 10rpx;
  color: #243447;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.24;
}

.role-copy {
  max-width: 560rpx;
  margin-top: 14rpx;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.62;
}

.resume-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #fff7ef, #fffaf4);
  box-shadow: 0 12rpx 28rpx rgba(181, 173, 159, 0.14);
}

.resume-title {
  color: #243447;
  font-size: 30rpx;
  font-weight: 800;
}

.resume-copy {
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.5;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.role-card {
  min-height: 156rpx;
  display: grid;
  grid-template-columns: 96rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  padding: 24rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(181, 173, 159, 0.14);
  text-align: left;
}

.role-card.elder {
  background: linear-gradient(180deg, #fff8f2, #fffdf9);
}

.role-card.caregiver {
  background: linear-gradient(180deg, #f2faf5, #fcfefc);
}

.role-card.admin {
  background: linear-gradient(180deg, #f7f6f2, #ffffff);
}

.role-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
}

.role-content {
  min-width: 0;
}

.role-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.role-name {
  color: #243447;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.role-chip {
  flex: 0 0 auto;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 20rpx;
  background: rgba(240, 161, 116, 0.14);
  color: #cb7c48;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.caregiver .role-chip {
  background: rgba(135, 201, 159, 0.18);
  color: #4d8d64;
}

.admin .role-chip {
  background: rgba(117, 176, 209, 0.14);
  color: #4d7f9a;
}

.role-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.5;
}

.role-action {
  margin-top: 10rpx;
  color: #243447;
  font-size: 26rpx;
  font-weight: 700;
}
