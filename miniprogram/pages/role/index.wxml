<view class="page no-tab role-page">
  <view class="role-hero card">
    <view class="role-art">
      <view class="role-art-ring role-art-ring-outer"></view>
      <view class="role-art-ring role-art-ring-inner"></view>
      <image class="role-mascot" src="{{mascot}}" mode="aspectFill" />
    </view>
    <text class="role-kicker">小鹅陪练</text>
    <text class="role-title">请选择身份</text>
    <text class="role-copy">老人练一练，家人看一看。</text>
  </view>

  <view wx:if="{{checkingLogin}}" class="resume-card">
    <text class="resume-title">正在登录</text>
    <text class="resume-copy">{{checkingText}}</text>
  </view>

  <view class="role-list">
    <button
      wx:for="{{roles}}"
      wx:key="role"
      class="role-card {{item.role}}"
      data-role="{{item.role}}"
      bindtap="chooseRole"
      disabled="{{checkingLogin}}"
    >
      <image class="role-icon" src="{{item.image}}" mode="aspectFill" />
      <view class="role-content">
        <view class="role-head">
          <text class="role-name">{{item.title}}</text>
          <text class="role-chip">{{item.role === 'elder' ? '练习' : '看护'}}</text>
        </view>
        <text class="role-desc">{{item.desc}}</text>
      </view>
    </button>
  </view>
</view>
