.elder-login-page {
  position: relative;
}

.login-hero,
.info-panel {
  margin-bottom: 22rpx;
}

.login-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: linear-gradient(180deg, #ffffff, #fcfaf6);
}

.hero-art {
  position: relative;
  width: 156rpx;
  height: 156rpx;
  margin-bottom: 18rpx;
}

.hero-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
}

.hero-ring-outer {
  background: rgba(240, 161, 116, 0.12);
  transform: scale(1.08);
}

.hero-ring-inner {
  background: linear-gradient(180deg, #ffe5d4, #fff6ef);
}

.doctor-goose {
  position: absolute;
  inset: 14rpx;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
}

.info-panel {
  padding: 28rpx;
}

.form-heading {
  margin-bottom: 12rpx;
}

.form-label,
.year-value,
.voice-assist-title,
.voice-assist-desc,
.voice-query,
.voice-answer {
  display: block;
}

.field-card {
  min-height: 128rpx;
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 2rpx solid #f0ebe2;
  border-radius: 26rpx;
  background: #fffdfa;
}

.name-card {
  min-height: 130rpx;
}

.field-main {
  min-width: 0;
}

.form-label {
  margin-bottom: 12rpx;
  color: #243447;
  font-size: 28rpx;
  font-weight: 800;
}

.gender-row {
  display: flex;
  width: 100%;
  min-width: 0;
  height: 78rpx;
  padding: 4rpx;
  border: 2rpx solid #e8e1d7;
  border-radius: 22rpx;
  background: #ffffff;
  overflow: hidden;
}

.gender-btn {
  flex: 1 1 0;
  min-width: 0;
  height: 66rpx;
  border-radius: 18rpx;
  background: transparent;
  color: #243447;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 66rpx;
  text-align: center;
}

.gender-btn.active {
  background: #fff3ea;
  color: #cb7c48;
}

.name-input {
  height: 78rpx;
  padding: 0 22rpx;
  border: 2rpx solid #e8e1d7;
  border-radius: 22rpx;
  background: #ffffff;
  color: #243447;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 78rpx;
}

.input-placeholder {
  color: #b0a89b;
  font-weight: 700;
}

.year-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.year-head .form-label {
  margin-bottom: 0;
}

.year-value {
  flex: 0 0 auto;
  min-width: 142rpx;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #fff3ea;
  color: #243447;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 52rpx;
  text-align: center;
}

.submit-btn {
  margin-top: 20rpx;
}

.voice-assist-card {
  width: 100%;
  min-height: 104rpx;
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr) 28rpx;
  gap: 16rpx;
  align-items: center;
  padding: 18rpx 22rpx;
  border-radius: 26rpx;
  background: #edf8f1;
  color: #243447;
  text-align: left;
}

.voice-assist-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #fff6ef;
}

.voice-assist-copy {
  min-width: 0;
}

.voice-assist-title {
  color: #243447;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.3;
}

.voice-assist-desc {
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.35;
}

.voice-assist-arrow {
  color: #7cae8f;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1;
  text-align: right;
}

.voice-card {
  border-radius: 34rpx;
}

.voice-head {
  display: grid;
  grid-template-columns: 104rpx minmax(0, 1fr);
  gap: 22rpx;
  align-items: center;
}

.voice-ring {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #fff3ea;
  color: #cb7c48;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 104rpx;
  text-align: center;
}

.voice-ring.listening {
  border: 8rpx solid rgba(240, 161, 116, 0.26);
  box-shadow: 0 0 0 12rpx rgba(240, 161, 116, 0.12);
}

.voice-result {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin: 24rpx 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f7f4ee;
}

.voice-query {
  color: #667085;
  font-size: 26rpx;
  line-height: 1.45;
}

.voice-answer {
  color: #243447;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.58;
}

.voice-main-btn {
  width: 100%;
  height: 84rpx;
  margin-bottom: 22rpx;
  border-radius: 24rpx;
  background: #87c99f;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 84rpx;
}

.voice-main-btn.recording {
  background: #d95745;
}

.tip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.tip-btn {
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #edf8f1;
  color: #4d8d64;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 64rpx;
}
