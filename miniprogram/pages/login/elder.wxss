.elder-login-page {
  position: relative;
  min-height: 100vh;
  padding: 0 0 48rpx;
  overflow: visible;
  background: linear-gradient(180deg, #FCFBF8 0%, #F7F5F0 42%, #F7F5F0 100%);
}

.top-space {
  height: 120rpx;
}

.avatar-wrap {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: center;
  margin-bottom: -66rpx;
}

.doctor-goose {
  width: 192rpx;
  height: 192rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  background: #EFA777;
  box-shadow: 0 16rpx 46rpx rgba(191, 119, 73, 0.24);
}

.info-panel {
  min-height: 760rpx;
  padding: 102rpx 30rpx 28rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #FFFFFF;
  box-shadow: 0 -10rpx 34rpx rgba(220, 215, 205, 0.42);
}

.panel-title {
  display: block;
  margin-bottom: 42rpx;
  color: #3F3F3F;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
}

.form-block {
  margin-bottom: 34rpx;
}

.form-label {
  display: block;
  margin-bottom: 16rpx;
  color: #6B6B6B;
  font-size: 30rpx;
  font-weight: 800;
}

.gender-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.gender-btn {
  height: 88rpx;
  border: 2rpx solid #EFEDEA;
  border-radius: 28rpx;
  background: #FFFFFF;
  color: #3F3F3F;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 88rpx;
  text-align: center;
}

.gender-btn.active {
  border-color: #EDB189;
  background: #EDB189;
  color: #FFFFFF;
}

.name-input {
  height: 88rpx;
  padding: 0 26rpx;
  border: 4rpx solid #CDA64C;
  border-radius: 28rpx;
  color: #3F3F3F;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 88rpx;
}

.input-placeholder {
  color: #B8B2AA;
  font-weight: 700;
}

.year-value {
  display: block;
  margin-top: -8rpx;
  color: #3F3F3F;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
  text-align: center;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  margin-top: 22rpx;
  border-radius: 28rpx;
  background: #EDB189;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 96rpx;
  text-align: center;
}

.voice-float {
  position: fixed;
  right: 22rpx;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  z-index: 8;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-width: 156rpx;
  height: 72rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #8FD3A8 0%, #6FBE91 100%);
  color: #FFFFFF;
  box-shadow:
    0 14rpx 34rpx rgba(111, 190, 145, 0.36),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.36);
  box-sizing: border-box;
}

.voice-float::after {
  border: 0;
}

.voice-icon {
  display: block;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.voice-card {
  border-radius: 34rpx;
}

.voice-head {
  display: grid;
  grid-template-columns: 104rpx 1fr;
  gap: 22rpx;
  align-items: center;
}

.voice-ring {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #FFF0E8;
  color: #C66F3C;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 104rpx;
  text-align: center;
}

.voice-ring.listening {
  border: 8rpx solid rgba(244, 168, 130, 0.34);
  box-shadow: 0 0 0 12rpx rgba(244, 168, 130, 0.14);
}

.voice-result {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin: 28rpx 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #F7F5F0;
}

.voice-query {
  color: #6B6B6B;
  font-size: 26rpx;
  line-height: 1.45;
}

.voice-answer {
  color: #3F3F3F;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.55;
}

.voice-main-btn {
  width: 100%;
  height: 84rpx;
  margin-bottom: 22rpx;
  border-radius: 42rpx;
  background: #88C9A1;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 84rpx;
}

.voice-main-btn.recording {
  background: #F4A882;
}

.tip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.tip-btn {
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 32rpx;
  background: #F0F9F4;
  color: #4F9A68;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 64rpx;
}
