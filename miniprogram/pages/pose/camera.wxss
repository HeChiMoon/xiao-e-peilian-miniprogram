.camera-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #101010;
  overflow: hidden;
}

.camera-shell {
  position: relative;
  flex: 0 0 65vh;
  min-height: 700rpx;
  background: #000000;
}

.camera-view {
  width: 100%;
  height: 100%;
}

.body-frame {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 28rpx;
  bottom: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  border: 4rpx dashed rgba(135, 201, 159, 0.94);
  border-radius: 34rpx;
  color: #ffffff;
  text-align: center;
  pointer-events: none;
}

.frame-title {
  font-size: 34rpx;
  font-weight: 800;
}

.frame-copy {
  max-width: calc(100% - 48rpx);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.5);
  font-size: 25rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.control-panel {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  background: #f6f3ec;
  border-radius: 28rpx 28rpx 0 0;
  overflow: hidden;
}

.panel-scroll {
  flex: 1;
  min-height: 0;
}

.panel-content {
  padding: 20rpx 24rpx 16rpx;
}

.action-info,
.status-box,
.result-box {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(181, 173, 159, 0.12);
}

.status-box,
.result-box {
  margin-top: 18rpx;
}

.action-name,
.action-guide,
.status-box text,
.result-label,
.result-value,
.suggestion {
  display: block;
}

.action-name {
  color: #243447;
  font-size: 32rpx;
  font-weight: 800;
}

.action-guide {
  margin-top: 8rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.55;
}

.status-box {
  color: #667085;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.status-box.pass {
  background: #edf8f1;
  color: #4d8d64;
}

.success-panel {
  margin-top: 18rpx;
  min-height: 300rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  background: #edf8f1;
}

.success-word {
  display: block;
  color: #4d8d64;
  font-size: 56rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1;
  white-space: nowrap;
}

.success-hint,
.success-tip {
  display: block;
  color: #5f7567;
  text-align: center;
}

.success-hint {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.success-tip {
  font-size: 24rpx;
  line-height: 1.35;
}

.result-box {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.result-box view {
  min-height: 92rpx;
  padding: 12rpx 10rpx;
  border-radius: 18rpx;
  background: #f7f4ee;
  box-sizing: border-box;
}

.result-label {
  color: #667085;
  font-size: 22rpx;
}

.result-value {
  margin-top: 8rpx;
  color: #243447;
  font-size: 32rpx;
  font-weight: 800;
}

.suggestion {
  grid-column: 1 / 3;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.55;
}

.action-bar {
  flex-shrink: 0;
  display: grid;
  gap: 14rpx;
  padding: 16rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(36, 52, 71, 0.08);
  background: #f6f3ec;
  box-shadow: 0 -10rpx 24rpx rgba(0, 0, 0, 0.04);
}

.camera-toolbar-card {
  padding: 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(181, 173, 159, 0.1);
}

.camera-toolbar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.camera-toolbar-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.camera-toolbar-label,
.camera-toolbar-value,
.camera-toolbar-tag {
  display: block;
}

.camera-toolbar-label {
  color: #8a857d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}

.camera-toolbar-value {
  color: #243447;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.camera-toolbar-tag {
  flex: 0 0 auto;
  min-width: 88rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #edf8f1;
  color: #4d8d64;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  line-height: 1.2;
}

.camera-switch-btn {
  width: 100%;
  min-height: 88rpx;
  margin-top: 16rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #edf8f1;
  color: #4d8d64;
  border: 2rpx solid rgba(77, 141, 100, 0.2);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.camera-switch-btn[disabled] {
  opacity: 0.45;
}

.camera-switch-btn::after {
  border: 0;
}

.primary-btn,
.retry-btn,
.outline-btn {
  height: 92rpx;
  border-radius: 24rpx;
}

.retry-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0a174;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 800;
}

.retry-btn::after {
  border: 0;
}

.rotate-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

@media (max-width: 360px) {
  .camera-shell {
    flex-basis: 62vh;
    min-height: 620rpx;
  }

  .result-box {
    grid-template-columns: 1fr;
  }

  .suggestion {
    grid-column: 1;
  }

  .success-word {
    font-size: 48rpx;
  }
}
