.pose-history-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.history-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.summary-card {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(220, 215, 205, 0.42);
}

.summary-label,
.summary-value {
  display: block;
}

.summary-label {
  color: #6B6B6B;
  font-size: 24rpx;
}

.summary-value {
  margin-top: 12rpx;
  color: #3F3F3F;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.3;
}

.summary-value.small {
  font-size: 26rpx;
  overflow-wrap: anywhere;
}

.empty-card {
  min-height: 180rpx;
  padding: 34rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
  background: #FFFFFF;
  color: #6B6B6B;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: center;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.history-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.history-title,
.history-time,
.history-label,
.history-value,
.history-suggestion {
  display: block;
}

.history-title {
  color: #3F3F3F;
  font-size: 34rpx;
  font-weight: 900;
}

.history-time {
  margin-top: 8rpx;
  color: #9A948A;
  font-size: 24rpx;
}

.risk-pill {
  min-width: 128rpx;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 52rpx;
  text-align: center;
}

.risk-pill.safe {
  background: #F0F9F4;
  color: #4F9A68;
}

.risk-pill.warning {
  background: #FFF8E1;
  color: #8A4A00;
}

.risk-pill.danger {
  background: #FFF0E8;
  color: #C66F3C;
}

.history-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.history-grid view {
  min-height: 116rpx;
  padding: 16rpx 12rpx;
  border-radius: 20rpx;
  background: #F7F5F0;
}

.history-label {
  color: #6B6B6B;
  font-size: 22rpx;
}

.history-value {
  margin-top: 10rpx;
  color: #3F3F3F;
  font-size: 32rpx;
  font-weight: 900;
}

.history-value.small {
  font-size: 22rpx;
  line-height: 1.3;
  overflow-wrap: anywhere;
}

.history-suggestion {
  color: #6B6B6B;
  font-size: 28rpx;
  line-height: 1.55;
}

.history-link {
  display: block;
  color: #4F9A68;
  font-size: 26rpx;
  font-weight: 900;
  text-align: right;
}

@media (max-width: 360px) {
  .history-grid {
    grid-template-columns: 1fr;
  }
}
