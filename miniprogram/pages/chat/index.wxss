.chat-page {
  height: 100vh;
  padding-bottom: calc(356rpx + env(safe-area-inset-bottom));
}

.chat-scroll {
  height: calc(100vh - 374rpx - env(safe-area-inset-bottom));
}

.chat-hero {
  margin-bottom: 22rpx;
  background: linear-gradient(180deg, #ffffff, #fcfaf6);
}

.message {
  display: flex;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  border-radius: 24rpx;
  background: #f0a174;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 64rpx;
  text-align: center;
  overflow: hidden;
}

.message.user .avatar {
  background: #87c99f;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
  background: #fff6ef;
}

.bubble {
  max-width: 560rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #243447;
  font-size: 28rpx;
  line-height: 1.62;
  box-shadow: 0 10rpx 24rpx rgba(181, 173, 159, 0.14);
}

.message.user .bubble {
  background: #fff3ea;
}

.bubble-text {
  display: block;
}

.bubble-audio-btn {
  min-width: 110rpx;
  min-height: 56rpx;
  margin: 16rpx 0 0 auto;
  padding: 0 16rpx;
  border-radius: 18rpx;
  background: #f5f4f1;
  color: #243447;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.bubble-audio-btn::after {
  border: 0;
}

.bubble-audio-btn.playing {
  background: #87c99f;
  color: #ffffff;
}

.faq-card {
  padding: 26rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(181, 173, 159, 0.12);
}

.faq-title {
  display: block;
  margin: 2rpx 0 16rpx;
  color: #243447;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.4;
}

.faq-item {
  min-height: 74rpx;
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: #f7f4ee;
  color: #243447;
  font-size: 26rpx;
  line-height: 1.4;
  text-align: left;
}

.voice-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(34rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #eee7dd;
  box-shadow: 0 -10rpx 28rpx rgba(181, 173, 159, 0.14);
}

.voice-status {
  display: block;
  margin: 14rpx 0 16rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
}

.voice-main {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  height: 108rpx;
  border-radius: 28rpx;
  background: #87c99f;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 108rpx;
  box-shadow: 0 14rpx 24rpx rgba(135, 201, 159, 0.22);
}

.voice-main::after {
  border: 0;
}

.voice-main-icon {
  font-size: 38rpx;
  line-height: 1;
}

.voice-main-text {
  line-height: 1;
}

.voice-main.recording {
  background: #d95745;
  box-shadow: 0 14rpx 24rpx rgba(217, 87, 69, 0.22);
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

.input-bar input {
  flex: 1 1 0;
  min-width: 0;
  height: 78rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #f7f4ee;
  color: #243447;
  font-size: 28rpx;
  box-sizing: border-box;
}

.send-btn {
  flex: 0 0 116rpx;
  width: 116rpx;
  min-width: 116rpx;
  height: 78rpx;
  border-radius: 18rpx;
  background: #f0a174;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 78rpx;
  text-align: center;
}

.send-btn.disabled {
  opacity: 0.6;
}
