.records-page {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.hero-card,
.summary-card {
  padding: 34rpx;
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(220, 215, 205, 0.62);
}

.summary-card {
  background: #F0F9F4;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.mini-card {
  min-height: 132rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.82);
}

.mini-label,
.mini-value {
  display: block;
}

.mini-label {
  color: #6B6B6B;
  font-size: 24rpx;
}

.mini-value {
  margin-top: 12rpx;
  color: #3F3F3F;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.3;
}

.mini-value.small {
  font-size: 28rpx;
  overflow-wrap: anywhere;
}

.summary-value,
.summary-label,
.summary-copy {
  display: block;
}

.summary-value {
  color: #4F9A68;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.1;
}

.summary-label {
  margin-top: 12rpx;
  color: #3F3F3F;
  font-size: 32rpx;
  font-weight: 900;
}

.summary-copy {
  margin-top: 14rpx;
  color: #6B6B6B;
  font-size: 30rpx;
  line-height: 1.55;
}

.level-row {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-bottom: 1rpx solid #E8E6E1;
  color: #3F3F3F;
  font-size: 30rpx;
  font-weight: 800;
}

.level-row text:first-child {
  min-width: 0;
  flex: 1;
  line-height: 1.35;
}

.level-row text:last-child {
  flex: 0 0 auto;
  color: #6B6B6B;
  font-size: 26rpx;
}

.level-row:last-child {
  border-bottom: 0;
}

.level-row.done {
  color: #4F9A68;
}

.level-row.done text:last-child {
  color: #4F9A68;
}

.empty-text {
  padding: 30rpx 0 4rpx;
  color: #6B6B6B;
  font-size: 30rpx;
  line-height: 1.55;
}

.home-btn {
  margin-top: 4rpx;
}
