.home-page {
  position: relative;
}

.hero-card {
  min-height: 300rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 136rpx;
  gap: 20rpx;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 34rpx;
  border-radius: 34rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(220, 215, 205, 0.62);
}

.hello,
.hero-title,
.subtitle {
  display: block;
}

.hello {
  margin-bottom: 12rpx;
  color: #F4A882;
  font-size: 28rpx;
  font-weight: 900;
}

.hero-goose {
  width: 136rpx;
  height: 136rpx;
  border: 8rpx solid #FFF0E8;
  border-radius: 50%;
}

.status-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-bottom: 26rpx;
}

.mini-card.wide {
  grid-column: 1 / 3;
}

.mini-card {
  min-height: 132rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.82);
  overflow: hidden;
}

.mini-label,
.mini-value {
  display: block;
}

.mini-label {
  color: #6B6B6B;
  font-size: 24rpx;
}

.mini-value {
  margin-top: 12rpx;
  color: #3F3F3F;
  font-size: 40rpx;
  font-weight: 900;
}

.mini-value.small {
  overflow-wrap: anywhere;
  font-size: 28rpx;
  line-height: 1.35;
}

.feature-card {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.focus-card {
  margin-bottom: 26rpx;
  background: #FFF7EF;
}

.pose-entry {
  background: #F5F8FF;
}

.card-action {
  width: 100%;
  max-width: 260rpx;
}

.video-entry {
  overflow: hidden;
  padding-bottom: 24rpx;
}

.video-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 132rpx;
  gap: 18rpx;
  align-items: center;
}

.video-copy {
  min-width: 0;
}

.video-reason {
  display: block;
  margin-top: 14rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background: #F0F9F4;
  color: #4F9A68;
  font-size: 24rpx;
  line-height: 1.35;
}

.video-mascot {
  width: 132rpx;
  height: 132rpx;
  border-radius: 24rpx;
  background: #F4A882;
  box-shadow: 0 16rpx 34rpx rgba(136, 201, 161, 0.2);
}

.video-cover {
  height: 228rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  border-radius: 24rpx;
  background: #E8E6E1;
}

.play-mark {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(244, 168, 130, 0.9);
  color: #FFFFFF;
  font-size: 46rpx;
  line-height: 96rpx;
  text-align: center;
}

.float-chat {
  position: fixed;
  right: 24rpx;
  bottom: calc(128rpx + env(safe-area-inset-bottom));
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: auto;
  height: 86rpx;
  max-width: 236rpx;
  padding: 0 24rpx 0 14rpx;
  border-radius: 43rpx;
  background: #88C9A1;
  box-shadow: 0 14rpx 34rpx rgba(136, 201, 161, 0.45);
  box-sizing: border-box;
}

.float-chat-icon {
  width: 58rpx;
  height: 58rpx;
  flex: 0 0 58rpx;
  border-radius: 50%;
  background: #FFF0E8;
}

.float-chat-text {
  flex: 0 0 auto;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}
