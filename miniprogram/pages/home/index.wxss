.home-page {
  position: relative;
}

.hero-card {
  min-height: 286rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
  padding: 38rpx 32rpx;
  border-radius: 34rpx;
  background: linear-gradient(180deg, #ffffff, #fdfbf7);
  box-shadow: 0 16rpx 40rpx rgba(181, 173, 159, 0.16);
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hello,
.hero-title,
.subtitle,
.hero-tag {
  display: block;
}

.hello {
  margin-bottom: 10rpx;
  color: #e29063;
  font-size: 26rpx;
  font-weight: 700;
}

.home-page .hero-title {
  max-width: 100%;
  color: #243447;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.18;
}

.home-page .subtitle {
  display: none;
  margin-top: 14rpx;
  max-width: 96%;
  color: #667085;
  font-size: 29rpx;
  line-height: 1.62;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.hero-tag {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  background: #f5efe5;
  color: #7a6c5d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.hero-art {
  position: relative;
  width: 138rpx;
  height: 138rpx;
  margin-left: auto;
}

.hero-orbit {
  position: absolute;
  inset: 0;
  border-radius: 50%;
}

.hero-orbit-outer {
  background: rgba(240, 161, 116, 0.12);
  transform: scale(1.08);
}

.hero-orbit-inner {
  background: linear-gradient(180deg, #ffe5d4, #fff6ef);
  box-shadow: inset 0 0 0 2rpx rgba(240, 161, 116, 0.14);
}

.hero-goose {
  position: absolute;
  inset: 14rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  object-fit: cover;
}

.status-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.mini-card,
.mini-card.wide {
  flex: 1 1 0;
  min-height: 122rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 10rpx 30rpx rgba(181, 173, 159, 0.1);
}

.mini-card.wide {
  flex-basis: 100%;
  min-height: 106rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.mini-label,
.mini-value {
  display: block;
}

.mini-label {
  color: #7a7f87;
  font-size: 23rpx;
  font-weight: 700;
}

.mini-value {
  margin-top: 12rpx;
  color: #243447;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.15;
}

.mini-value.small {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.45;
  overflow-wrap: anywhere;
}

.mini-card.wide .mini-label,
.mini-card.wide .mini-value {
  margin-top: 0;
}

.feature-card {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.feature-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: center;
}

.feature-copy {
  flex: 1;
  min-width: 0;
}

.feature-visual {
  width: 136rpx;
  height: 136rpx;
  border-radius: 30rpx;
  background: #fff9f3;
}

.green .feature-visual {
  background: #f0faf4;
}

.focus-card {
  background: linear-gradient(180deg, #fff7ef, #fffaf5);
}

.card-action {
  width: 100%;
}

.video-entry {
  overflow: hidden;
}

.video-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
}

.video-copy {
  flex: 1;
  min-width: 0;
}

.video-reason {
  display: block;
  margin-top: 14rpx;
  color: #5f7487;
  font-size: 24rpx;
  line-height: 1.5;
}

.video-preview {
  position: relative;
  width: 152rpx;
  height: 152rpx;
  margin-left: auto;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #eff7fb, #f8fbfd);
  box-shadow: inset 0 0 0 2rpx rgba(117, 176, 209, 0.1);
}

.video-mascot {
  position: absolute;
  inset: 18rpx;
  width: 116rpx;
  height: 116rpx;
  border-radius: 24rpx;
  object-fit: contain;
}

.play-badge {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(36, 52, 71, 0.84);
}

.play-mark {
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1;
}

.float-chat {
  position: fixed;
  right: 22rpx;
  bottom: calc(136rpx + env(safe-area-inset-bottom));
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 146rpx;
  height: 76rpx;
  padding: 10rpx 16rpx 10rpx 12rpx;
  border-radius: 38rpx;
  background: rgba(135, 201, 159, 0.96);
  box-shadow: 0 16rpx 28rpx rgba(135, 201, 159, 0.22);
}

.float-chat-icon {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 52rpx;
  border-radius: 26rpx;
  background: #fff6ef;
}

.float-chat-copy {
  min-width: 0;
}

.float-chat-label,
.float-chat-text {
  display: block;
  color: #ffffff;
}

.float-chat-label {
  font-size: 18rpx;
  line-height: 1.2;
  opacity: 0.88;
}

.float-chat-text {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.1;
}
