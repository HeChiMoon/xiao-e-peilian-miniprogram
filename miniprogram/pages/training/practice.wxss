.practice-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.practice-head {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.vision-rule {
  padding: 22rpx 24rpx;
  border-left: 8rpx solid #88c9a1;
  border-radius: 22rpx;
  background: #f0f9f4;
}

.vision-rule-name,
.vision-rule-hint {
  display: block;
}

.vision-rule-name {
  color: #4f9a68;
  font-size: 28rpx;
  font-weight: 900;
}

.vision-rule-hint {
  margin-top: 8rpx;
  color: #5f7567;
  font-size: 26rpx;
  line-height: 1.5;
}

.assistant-title,
.assistant-copy {
  display: block;
}

.assistant-title {
  font-size: 32rpx;
  font-weight: 900;
}

.assistant-copy {
  margin-top: 10rpx;
  color: #6b6b6b;
  font-size: 28rpx;
  line-height: 1.55;
}

.practice-progress {
  margin-top: 26rpx;
  color: #3f3f3f;
  font-size: 28rpx;
  font-weight: 800;
}

.progress-track {
  height: 24rpx;
  overflow: hidden;
  margin-top: 16rpx;
  border-radius: 12rpx;
  background: #e8e6e1;
}

.progress-fill {
  height: 100%;
  border-radius: 12rpx;
  background: #88c9a1;
}

.quality-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.quality-item {
  min-height: 92rpx;
  padding: 14rpx 8rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: #f7f5f0;
  color: #6b6b6b;
}

.quality-item.ok {
  background: #f0f9f4;
  color: #4f9a68;
}

.quality-item.warn {
  background: #fff0e8;
  color: #c66f3c;
}

.quality-label,
.quality-value {
  display: block;
}

.quality-label {
  font-size: 22rpx;
  font-weight: 700;
}

.quality-value {
  font-size: 26rpx;
  font-weight: 900;
}

.complete-card {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: #f0f9f4;
}

.complete-title {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4f9a68;
  font-size: 42rpx;
  font-weight: 900;
  text-align: center;
  line-height: 1;
  white-space: nowrap;
}

.complete-hint,
.complete-tip {
  display: block;
  color: #5f7567;
  text-align: center;
}

.complete-hint {
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
}

.complete-tip {
  font-size: 24rpx;
  line-height: 1.35;
}

.practice-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.wide {
  grid-column: 1 / 3;
}

.quit-btn {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #e8e6e1;
  border-radius: 46rpx;
  background: #ffffff;
  color: #6b6b6b;
  font-size: 32rpx;
  font-weight: 900;
}

@media (max-width: 360px) {
  .quality-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
