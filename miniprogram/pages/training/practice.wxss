.practice-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.practice-head {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.vision-rule {
  padding: 22rpx 24rpx;
  border-left: 8rpx solid #87c99f;
  border-radius: 22rpx;
  background: #edf8f1;
}

.vision-rule-name,
.vision-rule-hint,
.assistant-title,
.assistant-copy {
  display: block;
}

.vision-rule-name {
  color: #4d8d64;
  font-size: 28rpx;
  font-weight: 800;
}

.vision-rule-hint {
  margin-top: 8rpx;
  color: #5f7567;
  font-size: 26rpx;
  line-height: 1.5;
}

.assistant-title {
  font-size: 32rpx;
  font-weight: 800;
}

.assistant-copy {
  margin-top: 10rpx;
  color: #667085;
  font-size: 28rpx;
  line-height: 1.55;
}

.practice-progress {
  margin-top: 24rpx;
  color: #243447;
  font-size: 28rpx;
  font-weight: 700;
}

.progress-track {
  height: 24rpx;
  overflow: hidden;
  margin-top: 16rpx;
  border-radius: 12rpx;
  background: #ebe6de;
}

.progress-fill {
  height: 100%;
  border-radius: 12rpx;
  background: #87c99f;
}

.quality-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.quality-item {
  min-height: 92rpx;
  padding: 14rpx 8rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: #f7f4ee;
  color: #667085;
}

.quality-item.ok {
  background: #edf8f1;
  color: #4d8d64;
}

.quality-item.warn {
  background: #fff3ea;
  color: #cb7c48;
}

.quality-label,
.quality-value {
  display: block;
}

.quality-label {
  font-size: 22rpx;
  font-weight: 700;
}

.quality-value {
  font-size: 26rpx;
  font-weight: 800;
}

.complete-card {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: #edf8f1;
}

.complete-title {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4d8d64;
  font-size: 42rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1;
  white-space: nowrap;
}

.complete-hint,
.complete-tip {
  display: block;
  color: #5f7567;
  text-align: center;
}

.complete-hint {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.complete-tip {
  font-size: 24rpx;
  line-height: 1.35;
}

.practice-actions {
  display: flex;
}

.wide {
  width: 100%;
}

@media (max-width: 360px) {
  .quality-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
