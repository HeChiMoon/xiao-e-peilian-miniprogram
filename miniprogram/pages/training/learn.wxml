<view class="page no-tab learn-page" wx:if="{{level}}">
  <view class="video-shell">
    <image
      class="learn-video learn-image"
      src="{{level.image}}"
      mode="aspectFit"
    />
    <view class="subtitle-bar">{{level.guide}}</view>
  </view>

  <view class="card">
    <view class="top-row">
      <image class="round-img" src="{{level.image}}" mode="aspectFill" />
      <view>
        <text class="section-kicker sky-kicker">动作学习</text>
        <text class="card-title">{{level.name}}</text>
        <text class="card-copy">{{level.description}}</text>
      </view>
    </view>
  </view>

  <view class="action-grid">
    <button class="outline-btn" bindtap="notYet">再看一遍</button>
    <button class="primary-btn" bindtap="understood">学会了</button>
  </view>

  <view wx:if="{{showDialog}}" class="modal-mask" bindtap="closeDialog">
    <view class="modal-card goose-dialog" catchtap="noop">
      <view class="modal-body">
        <image class="dialog-img" src="/assets/images/xiao-e-icons/voice-assistant.png" mode="aspectFit" />
        <text class="dialog-title">太棒了</text>
        <text class="dialog-copy">动作看明白了，我们就进入练习。小鹅会陪着您慢慢做。</text>
        <button class="primary-btn" bindtap="startPractice">进入练习</button>
      </view>
    </view>
  </view>
</view>
