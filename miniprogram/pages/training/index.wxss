.training-page {
  padding-bottom: 52rpx;
}

.progress-card,
.plan-card,
.hint-card {
  margin-bottom: 22rpx;
}

.progress-card,
.plan-card {
  background: linear-gradient(180deg, #ffffff, #fcfaf6);
}

.finish-tip {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #edf8f1, #f8fcf9);
}

.finish-title,
.plan-kicker,
.plan-focus,
.tip-item,
.hint-name,
.hint-text,
.map-title {
  display: block;
}

.finish-title {
  color: #4d8d64;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.5;
}

.restart-btn {
  margin-top: 14rpx;
  height: 78rpx;
  border: 0;
  border-radius: 24rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #4d8d64;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.restart-btn::after {
  border: 0;
}

.plan-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.plan-copy {
  min-width: 0;
}

.plan-kicker {
  margin-bottom: 8rpx;
  color: #4d8d64;
  font-size: 23rpx;
  font-weight: 700;
}

.plan-focus {
  flex: 0 0 auto;
  max-width: 180rpx;
  padding: 10rpx 16rpx;
  border-radius: 20rpx;
  background: #edf8f1;
  color: #4d8d64;
  font-size: 23rpx;
  font-weight: 700;
  text-align: center;
  line-height: 1.3;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tip-item {
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: #f7f4ee;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.45;
}

.progress-track {
  height: 24rpx;
  overflow: hidden;
  margin-top: 20rpx;
  border-radius: 12rpx;
  background: #ebe6de;
}

.progress-fill {
  height: 100%;
  border-radius: 12rpx;
  background: #87c99f;
}

.map-card {
  position: relative;
  min-height: 670rpx;
  padding: 26rpx 24rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #eef8f1 100%);
  box-shadow: 0 12rpx 34rpx rgba(181, 173, 159, 0.16);
}

.map-head {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.map-title {
  color: #243447;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
}

.map-card::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 164rpx;
  bottom: 110rpx;
  width: 12rpx;
  border-radius: 10rpx;
  background: rgba(240, 161, 116, 0.24);
  transform: translateX(-50%);
}

.level-node {
  position: absolute;
  width: 194rpx;
  min-height: 194rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 18rpx;
  border: 8rpx solid #ffffff;
  border-radius: 50%;
  background: #f0a174;
  color: #ffffff;
  box-shadow: 0 18rpx 34rpx rgba(240, 161, 116, 0.28);
  box-sizing: border-box;
}

.level-node.locked {
  background: #e5e1d8;
  color: #6f6f6f;
  box-shadow: none;
}

.level-node.done {
  background: #87c99f;
}

.level-node.recommended {
  border-color: #fff4ed;
}

.level-node.focus {
  box-shadow: 0 18rpx 36rpx rgba(77, 141, 100, 0.28);
}

.node-badge {
  position: absolute;
  top: -16rpx;
  left: 50%;
  min-width: 92rpx;
  height: 38rpx;
  padding: 0 14rpx;
  border-radius: 19rpx;
  background: #243447;
  color: #ffffff;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 38rpx;
  text-align: center;
  transform: translateX(-50%);
  white-space: nowrap;
}

.node-1 { left: 46rpx; top: 122rpx; }
.node-2 { right: 46rpx; top: 268rpx; }
.node-3 { left: 46rpx; top: 414rpx; }

.node-number {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1;
}

.node-name {
  max-width: 156rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.28;
  text-align: center;
}

.node-status {
  margin-top: 8rpx;
  font-size: 20rpx;
  opacity: 0.84;
}

.hint-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.hint-row {
  display: grid;
  grid-template-columns: 128rpx minmax(0, 1fr);
  gap: 14rpx;
  align-items: start;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #f7f4ee;
}

.hint-name {
  color: #4d8d64;
  font-size: 25rpx;
  font-weight: 700;
}

.hint-text {
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}
