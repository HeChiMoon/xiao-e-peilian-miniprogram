<view class="page no-tab practice-page" wx:if="{{level}}">
  <view class="practice-head">
    <text class="section-kicker green-kicker">开始练习</text>
    <text class="hero-title">{{level.name}}</text>
    <text class="subtitle">{{level.guide}}</text>
    <view class="vision-rule">
      <text class="vision-rule-name">{{visionRuleName}}</text>
      <text class="vision-rule-hint">{{visionHint}}</text>
    </view>
  </view>

  <view class="card feedback-card">
    <view class="top-row">
      <image class="round-img" src="/assets/images/xiao-e-icons/pose-history.png" mode="aspectFit" />
      <view>
        <text class="assistant-title">小鹅动作练习</text>
        <text class="assistant-copy">先看清动作要求，再进入相机检测页面完成一次姿势判断。</text>
      </view>
    </view>

    <view class="practice-progress">
      <text>完成次数：{{count}}/{{total}}</text>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progressWidth}}"></view>
      </view>
    </view>

    <view class="quality-grid" wx:if="{{qualityItems.length}}">
      <view wx:for="{{qualityItems}}" wx:key="label" class="quality-item {{item.state}}">
        <text class="quality-label">{{item.label}}</text>
        <text class="quality-value">{{item.value}}</text>
      </view>
    </view>

    <view wx:if="{{completing}}" class="complete-card">
      <view class="complete-title">{{completeMessage}}</view>
      <text wx:if="{{!isFinalLevel}}" class="complete-hint">请稍等，正在进入下一关</text>
      <text wx:if="{{!isFinalLevel}}" class="complete-tip">小提示：可以先放松一下腿</text>
    </view>
  </view>

  <view wx:if="{{!completing}}" class="practice-actions">
    <button class="primary-btn wide" bindtap="goPoseCamera">进入相机检测</button>
  </view>
</view>
