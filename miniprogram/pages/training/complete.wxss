.complete-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.celebrate-card {
  width: 100%;
  padding: 48rpx 34rpx;
  border-radius: 36rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(220, 215, 205, 0.62);
  text-align: center;
}

.celebrate-img {
  width: 220rpx;
  height: 220rpx;
  border: 10rpx solid #FFD700;
  border-radius: 50%;
}

.celebrate-title,
.celebrate-copy {
  display: block;
}

.celebrate-title {
  margin-top: 30rpx;
  color: #F4A882;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.3;
}

.celebrate-copy {
  margin: 22rpx 0 34rpx;
  color: #6B6B6B;
  font-size: 30rpx;
  line-height: 1.65;
}

.back-btn {
  margin-top: 18rpx;
}
