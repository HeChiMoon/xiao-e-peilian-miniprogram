.complete-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.celebrate-card {
  width: 100%;
  text-align: center;
  background: linear-gradient(180deg, #ffffff, #fcfaf6);
}

.celebrate-img {
  width: 220rpx;
  height: 220rpx;
  border: 8rpx solid #ffe1c9;
  border-radius: 50%;
}

.celebrate-title,
.celebrate-copy {
  display: block;
}

.celebrate-title {
  margin-top: 18rpx;
  color: #cb7c48;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.3;
}

.celebrate-copy {
  margin: 18rpx 0 30rpx;
  color: #667085;
  font-size: 30rpx;
  line-height: 1.62;
}

.back-btn {
  margin-top: 16rpx;
}
