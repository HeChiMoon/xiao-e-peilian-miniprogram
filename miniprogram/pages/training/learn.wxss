.learn-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.video-shell {
  position: relative;
  overflow: hidden;
  border-radius: 30rpx;
  background: #111111;
  box-shadow: 0 12rpx 26rpx rgba(181, 173, 159, 0.16);
}

.learn-video {
  width: 100%;
  height: 420rpx;
}

.learn-image {
  display: block;
  background: #ffffff;
}

.subtitle-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 22rpx;
  background: rgba(17, 17, 17, 0.72);
  color: #ffffff;
  font-size: 26rpx;
  line-height: 1.45;
  text-align: center;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.goose-dialog {
  text-align: center;
}

.dialog-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
}

.dialog-title,
.dialog-copy {
  display: block;
}

.dialog-title {
  margin-top: 20rpx;
  color: #cb7c48;
  font-size: 40rpx;
  font-weight: 800;
}

.dialog-copy {
  margin: 18rpx 0 30rpx;
  color: #667085;
  font-size: 28rpx;
  line-height: 1.6;
}
