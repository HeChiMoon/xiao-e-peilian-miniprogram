.learn-page {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.video-shell {
  position: relative;
  overflow: hidden;
  border-radius: 30rpx;
  background: #000000;
}

.learn-video {
  width: 100%;
  height: 420rpx;
}

.learn-image {
  display: block;
  background: #ffffff;
}

.subtitle-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 22rpx;
  background: rgba(0, 0, 0, 0.68);
  color: #FFFFFF;
  font-size: 26rpx;
  line-height: 1.45;
  text-align: center;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.wide {
  grid-column: 1 / 3;
}

.quit-btn {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #E8E6E1;
  border-radius: 46rpx;
  background: #FFFFFF;
  color: #6B6B6B;
  font-size: 32rpx;
  font-weight: 900;
}

.penguin-dialog {
  text-align: center;
}

.dialog-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
}

.dialog-title,
.dialog-copy {
  display: block;
}

.dialog-title {
  margin-top: 20rpx;
  color: #F4A882;
  font-size: 40rpx;
  font-weight: 900;
}

.dialog-copy {
  margin: 18rpx 0 30rpx;
  color: #6B6B6B;
  font-size: 28rpx;
  line-height: 1.6;
}
