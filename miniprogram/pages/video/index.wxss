.short-video-page {
  position: relative;
  min-height: 100vh;
  padding: 0;
  background: #111111;
}

.loading-banner {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 20;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 24rpx;
  text-align: center;
}

.video-swiper {
  width: 100%;
  height: 100vh;
}

.video-slide {
  position: relative;
  width: 100%;
  height: 100vh;
  background: #111111;
}

.short-video {
  width: 100%;
  height: 100%;
  background: #222222;
}

.video-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.62), rgba(0, 0, 0, 0.08) 38%, rgba(0, 0, 0, 0.28));
}

.top-tip {
  padding: calc(44rpx + env(safe-area-inset-top)) 28rpx 0;
}

.tip-text {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 24rpx;
}

.bottom-panel {
  padding: 0 28rpx calc(42rpx + env(safe-area-inset-bottom));
  color: #ffffff;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.page-title {
  font-size: 32rpx;
  font-weight: 700;
}

.recommend-pill {
  flex: 0 0 auto;
  min-width: 108rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: #f4a882;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.video-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.video-desc {
  display: block;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  line-height: 1.6;
}

.recommend-reason {
  display: inline-block;
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(240, 249, 244, 0.18);
  color: #dff5e6;
  font-size: 24rpx;
  line-height: 1.5;
}
