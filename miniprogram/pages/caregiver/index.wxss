.header-card {
  margin-bottom: 24rpx;
}

.role-label,
.bound-tag,
.bound-title,
.bound-copy,
.bound-note,
.preview-label,
.preview-code,
.elder-name,
.mini-label,
.mini-value,
.dashboard-primary,
.dashboard-secondary {
  display: block;
}

.role-label {
  margin-bottom: 12rpx;
  color: #4d8d64;
  font-size: 26rpx;
  font-weight: 700;
}

.binding-card,
.elder-card,
.dashboard-card,
.pending-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title-with-icon {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-title-with-icon > view {
  min-width: 0;
}

.section-icon {
  flex: 0 0 auto;
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
}

.status-badge {
  flex: 0 0 auto;
  min-width: 108rpx;
  max-width: 168rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  overflow-wrap: anywhere;
}

.status-badge.idle {
  background: #f3f0ea;
  color: #847f76;
}

.status-badge.ready {
  background: #fff0e4;
  color: #cb7c48;
}

.status-badge.success {
  background: #edf8f1;
  color: #4d8d64;
}

.scan-tip,
.pending-note,
.dashboard-secondary {
  color: #667085;
  font-size: 25rpx;
  line-height: 1.58;
}

.binding-input {
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e8e1d7;
  border-radius: 24rpx;
  background: #ffffff;
  color: #243447;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.code-preview {
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff8f2, #fffdf9);
}

.preview-label {
  color: #cb7c48;
  font-size: 23rpx;
  font-weight: 700;
}

.preview-code {
  margin-top: 10rpx;
  color: #243447;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow-wrap: anywhere;
}

.binding-action-row {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.half-btn {
  flex: none;
  width: 100%;
  min-width: 0;
  margin: 0;
}

.bound-box {
  padding: 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #edf8f1, #f9fdf9);
}

.bound-tag {
  color: #4d8d64;
  font-size: 23rpx;
  font-weight: 700;
}

.bound-title,
.elder-name {
  margin-top: 8rpx;
  color: #243447;
  font-size: 34rpx;
  font-weight: 800;
}

.bound-copy {
  margin-top: 8rpx;
  color: #4d8d64;
  font-size: 26rpx;
  line-height: 1.45;
}

.bound-note {
  margin-top: 12rpx;
  color: #5f6f67;
  font-size: 25rpx;
  line-height: 1.6;
}

.elder-grid,
.dashboard-grid {
  display: grid;
  gap: 16rpx;
}

.elder-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.info-tile {
  min-width: 0;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f7f4ee;
}

.mini-label {
  color: #7a7f87;
  font-size: 23rpx;
  font-weight: 700;
}

.mini-value {
  margin-top: 10rpx;
  color: #243447;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.4;
  overflow-wrap: anywhere;
}

.mini-value.small {
  font-size: 26rpx;
}

.dashboard-grid {
  margin-top: 2rpx;
}

.dashboard-primary {
  color: #243447;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.pending-card .card-title {
  margin-top: -4rpx;
}

.reminder-row {
  min-height: 72rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #ece7df;
  color: #243447;
  font-size: 27rpx;
  line-height: 1.5;
}

.reminder-row:last-child {
  border-bottom: 0;
}

.back-btn {
  margin-top: 4rpx;
}
