.header-card {
  margin-bottom: 26rpx;
  padding: 34rpx;
  border-radius: 32rpx;
  background: #F0F9F4;
}

.role-label,
.bound-tag,
.bound-title,
.bound-copy,
.bound-note,
.preview-label,
.preview-code,
.elder-name,
.mini-label,
.mini-value,
.dashboard-primary,
.dashboard-secondary {
  display: block;
}

.role-label {
  margin-bottom: 12rpx;
  color: #4F9A68;
  font-size: 28rpx;
  font-weight: 900;
}

.binding-card,
.elder-card,
.dashboard-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.status-badge {
  flex: 0 0 auto;
  min-width: 120rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
}

.status-badge.idle {
  background: #F7F5F0;
  color: #8A857A;
}

.status-badge.ready {
  background: #FFF2E8;
  color: #D68143;
}

.status-badge.success {
  background: #EAF7EE;
  color: #4F9A68;
}

.scan-tip,
.pending-note,
.dashboard-secondary {
  color: #6B6B6B;
  font-size: 25rpx;
  line-height: 1.5;
}

.binding-input {
  height: 86rpx;
  padding: 0 24rpx;
  border: 3rpx solid #E8E6E1;
  border-radius: 24rpx;
  background: #FFFFFF;
  color: #3F3F3F;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 86rpx;
  box-sizing: border-box;
}

.code-preview {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #FFF9F1;
}

.preview-label {
  color: #B57645;
  font-size: 24rpx;
  font-weight: 800;
}

.preview-code {
  margin-top: 10rpx;
  color: #3F3F3F;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.3;
  overflow-wrap: anywhere;
}

.binding-action-row {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  padding-top: 6rpx;
}

.half-btn {
  flex: 1 1 0;
  width: auto;
  min-width: 0;
  height: 88rpx;
  font-size: 30rpx;
}

.binding-action-row .half-btn:first-child {
  flex: 0.96 1 0;
}

.binding-action-row .half-btn:last-child {
  flex: 1.04 1 0;
}

.bound-box {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #F0F9F4;
}

.bound-tag {
  color: #4F9A68;
  font-size: 24rpx;
  font-weight: 900;
}

.bound-title,
.elder-name {
  margin-top: 8rpx;
  color: #3F3F3F;
  font-size: 34rpx;
  font-weight: 900;
}

.bound-copy {
  margin-top: 8rpx;
  color: #4F9A68;
  font-size: 26rpx;
  line-height: 1.4;
}

.bound-note {
  margin-top: 14rpx;
  color: #5D6B62;
  font-size: 25rpx;
  line-height: 1.6;
}

.elder-grid,
.dashboard-grid {
  display: grid;
  gap: 18rpx;
}

.elder-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.elder-grid view {
  min-width: 0;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #F7F5F0;
}

.mini-label {
  color: #6B6B6B;
  font-size: 24rpx;
}

.mini-value {
  margin-top: 10rpx;
  color: #3F3F3F;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
  overflow-wrap: anywhere;
}

.mini-value.small {
  font-size: 26rpx;
}

.dashboard-grid {
  grid-template-columns: repeat(1, minmax(0, 1fr));
  margin-top: 26rpx;
}

.dashboard-card {
  gap: 14rpx;
}

.dashboard-primary {
  color: #3F3F3F;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
}

.reminder-row {
  min-height: 78rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #E8E6E1;
  color: #3F3F3F;
  font-size: 28rpx;
  font-weight: 800;
}

.reminder-row:last-child {
  border-bottom: 0;
}
