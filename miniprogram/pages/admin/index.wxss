.admin-hero {
  margin-bottom: 22rpx;
}

.role-label,
.metric-value,
.metric-label {
  display: block;
}

.role-label {
  margin-bottom: 12rpx;
  color: #cb7c48;
  font-size: 26rpx;
  font-weight: 700;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.metric-card {
  min-height: 146rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(181, 173, 159, 0.12);
}

.metric-value {
  color: #243447;
  font-size: 42rpx;
  font-weight: 800;
}

.metric-label {
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.35;
}

.task-card {
  margin-bottom: 22rpx;
  padding-bottom: 8rpx;
}

.task-row {
  width: 100%;
  min-height: 86rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #ece7df;
  color: #243447;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
  text-align: left;
}

.task-row:last-child {
  border-bottom: 0;
}
