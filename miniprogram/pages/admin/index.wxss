.admin-hero {
  margin-bottom: 26rpx;
  padding: 34rpx;
  border-radius: 32rpx;
  background: #FFF0E8;
}

.role-label,
.metric-value,
.metric-label {
  display: block;
}

.role-label {
  margin-bottom: 12rpx;
  color: #C66F3C;
  font-size: 28rpx;
  font-weight: 900;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-bottom: 26rpx;
}

.metric-card {
  min-height: 150rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(220, 215, 205, 0.62);
  overflow: hidden;
}

.metric-value {
  color: #3F3F3F;
  font-size: 44rpx;
  font-weight: 900;
}

.metric-label {
  margin-top: 10rpx;
  color: #6B6B6B;
  font-size: 26rpx;
  line-height: 1.35;
}

.task-card {
  margin-bottom: 26rpx;
  padding-bottom: 8rpx;
}

.task-row {
  width: 100%;
  min-height: 92rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E8E6E1;
  color: #3F3F3F;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.45;
  text-align: left;
}

.task-row:last-child {
  border-bottom: 0;
}
