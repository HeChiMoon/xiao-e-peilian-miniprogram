<view class="page no-tab report-page" wx:if="{{report}}">
  <view class="card report-card">
    <image class="report-goose" src="/assets/images/goose-main.png" mode="aspectFill" />
    <text class="report-title">小鹅测评 · 您的腿脚健康报告</text>
    <text class="report-date">{{report.createdAt}}</text>
    <view class="risk-badge {{report.className}}">{{report.levelText}}</view>
    <text class="score">风险分：{{report.score}}</text>
    <text class="summary">{{report.summary}}</text>
  </view>

  <view class="card">
    <text class="card-title">推荐训练计划</text>
    <text class="card-copy">{{report.suggestion}}</text>
  </view>

  <view class="card green">
    <text class="card-title">安全提醒</text>
    <text class="card-copy">测评结果只用于运动陪练和健康科普，不能替代医生诊断。如果哪里不舒服，请及时就医。</text>
  </view>

  <button class="primary-btn" bindtap="goTraining">进入每日练</button>
  <button class="outline-btn" bindtap="restart">重新测评</button>
  <button class="outline-btn" bindtap="backHome">返回首页</button>
</view>
