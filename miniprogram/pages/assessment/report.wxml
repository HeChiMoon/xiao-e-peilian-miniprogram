<view class="page no-tab report-page" wx:if="{{report}}">
  <view class="card report-card">
    <image class="report-goose" src="/assets/images/xiao-e-icons/health-archive.png" mode="aspectFit" />
    <text class="section-kicker peach-kicker">筛查结果</text>
    <text class="report-title">小鹅下肢功能筛查报告</text>
    <text class="report-date">{{report.createdAt}}</text>
    <view class="risk-badge {{report.className}}">{{report.levelText}}</view>
    <text class="score">风险分：{{report.score}}</text>
    <text class="summary">{{report.summary}}</text>
  </view>

  <view class="card">
    <text class="section-kicker green-kicker">维度分析</text>
    <text class="card-title">这几项最值得关注</text>
    <view class="dimension-grid">
      <view wx:for="{{dimensionCards}}" wx:key="key" class="dimension-card {{item.state}}">
        <view class="dimension-head">
          <text class="dimension-name">{{item.name}}</text>
          <text class="dimension-badge">{{item.priorityText}}</text>
        </view>
        <text class="dimension-score">{{item.score}} 分</text>
        <text class="dimension-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{canTrain}}" class="card">
    <text class="section-kicker peach-kicker">推荐计划</text>
    <text class="card-title">今日建议顺序</text>
    <text class="card-copy">{{report.suggestion}}</text>
    <view class="action-plan">
      <view wx:for="{{actionPlan}}" wx:key="id" class="action-row">
        <text class="action-index">{{item.index}}</text>
        <view class="action-copy">
          <text class="action-name">{{item.name}}</text>
          <text class="action-hint">{{item.hint}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="card blocked-card">
    <text class="section-kicker peach-kicker">先暂停训练</text>
    <text class="card-title">建议先做专业评估</text>
    <text class="card-copy">{{report.suggestion}}</text>
    <view wx:for="{{safetyReasons}}" wx:key="*this" class="reason-row">{{item}}</view>
  </view>

  <view class="card green">
    <text class="section-kicker sky-kicker">安全提醒</text>
    <text class="card-title">只做陪练和科普</text>
    <text class="card-copy">筛查结果只用于运动陪练和健康科普，不能替代医生诊断。如果哪里不舒服，请及时就医。</text>
  </view>

  <button wx:if="{{canTrain}}" class="primary-btn" bindtap="goTraining">进入每日练</button>
  <button wx:else class="primary-btn" bindtap="goVideo">先看健康知识</button>
  <button class="outline-btn" bindtap="restart">重新筛查</button>
  <button class="outline-btn" bindtap="backHome">返回首页</button>
</view>
