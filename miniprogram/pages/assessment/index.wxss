.assessment-page {
  padding-bottom: 44rpx;
}

.intro-card {
  text-align: center;
  background: linear-gradient(180deg, #ffffff, #fcfaf6);
}

.intro-goose {
  width: 188rpx;
  height: 188rpx;
  margin: 6rpx auto 24rpx;
  border-radius: 50%;
}

.intro-text {
  display: block;
  margin: 18rpx 0 24rpx;
  color: #4b5563;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.7;
}

.stage-header {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.stage-title {
  display: block;
  color: #243447;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.3;
}

.question-card {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.question-title {
  display: block;
  color: #243447;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.38;
}

.question-guide {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.58;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.nav-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.action-head {
  display: grid;
  grid-template-columns: 62rpx minmax(0, 1fr);
  gap: 16rpx;
  align-items: flex-start;
}

.action-copy {
  min-width: 0;
}

.action-index {
  width: 58rpx;
  height: 58rpx;
  border-radius: 29rpx;
  background: #f0a174;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
}

.camera-guide {
  height: 76rpx;
  font-size: 27rpx;
}

.action-modal {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-preview {
  width: 100%;
  height: 520rpx;
  border-radius: 24rpx;
  background: #f7f4ee;
}
