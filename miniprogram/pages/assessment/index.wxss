.assessment-page {
  padding-bottom: 44rpx;
}

.intro-card {
  text-align: center;
}

.intro-goose {
  width: 210rpx;
  height: 210rpx;
  margin-bottom: 24rpx;
  border-radius: 50%;
}

.intro-text {
  display: block;
  margin: 18rpx 0 24rpx;
  color: #3F3F3F;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.65;
}

.stage-title {
  display: block;
  color: #3F3F3F;
  font-size: 38rpx;
  font-weight: 900;
}

.question-card {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.question-title {
  display: block;
  color: #3F3F3F;
  font-size: 32rpx;
  font-weight: 900;
}

.question-guide {
  display: block;
  margin-top: 8rpx;
  color: #6B6B6B;
  font-size: 26rpx;
  line-height: 1.55;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.nav-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.action-head {
  display: grid;
  grid-template-columns: 60rpx 1fr;
  gap: 18rpx;
}

.action-index {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #F4A882;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
}

.camera-guide {
  height: 76rpx;
  font-size: 27rpx;
}

.action-modal {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-preview {
  width: 100%;
  height: 520rpx;
  border-radius: 24rpx;
  background: #F7F5F0;
}
