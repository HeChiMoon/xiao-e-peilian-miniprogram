.report-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.report-card {
  text-align: center;
  background: linear-gradient(180deg, #ffffff, #fcfaf6);
}

.report-goose {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto;
  border-radius: 50%;
}

.report-title,
.report-date,
.score,
.summary {
  display: block;
}

.report-title {
  margin-top: 18rpx;
  color: #243447;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
}

.report-date {
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
}

.risk-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  height: 62rpx;
  margin-top: 22rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.risk-badge.low { background: #87c99f; }
.risk-badge.medium { background: #f0a174; }
.risk-badge.high { background: #d95745; }

.score {
  margin-top: 18rpx;
  color: #cb7c48;
  font-size: 30rpx;
  font-weight: 800;
}

.summary {
  margin-top: 18rpx;
  color: #243447;
  font-size: 29rpx;
  line-height: 1.68;
}
