.edit-profile-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.header-card {
  background: #FFF0E8;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.form-row {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.form-label {
  color: #3F3F3F;
  font-size: 30rpx;
  font-weight: 900;
}

.form-input,
.form-textarea {
  width: 100%;
  border: 3rpx solid #E8E6E1;
  border-radius: 24rpx;
  background: #FFFFFF;
  color: #3F3F3F;
  font-size: 30rpx;
  font-weight: 800;
}

.form-input {
  height: 86rpx;
  padding: 0 24rpx;
  line-height: 86rpx;
}

.form-textarea {
  min-height: 150rpx;
  padding: 22rpx 24rpx;
  line-height: 1.55;
}

.double-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}
