.edit-profile-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.edit-profile-page .header-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.edit-profile-page .header-card .section-kicker {
  margin-bottom: 2rpx;
}

.edit-profile-page .header-card .hero-title {
  font-size: 40rpx;
}

.edit-profile-page .header-card .subtitle {
  margin-top: 0;
  max-width: 100%;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-row {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.form-label {
  color: #243447;
  font-size: 29rpx;
  font-weight: 800;
}

.form-input,
.form-textarea {
  width: 100%;
  border: 2rpx solid #e8e1d7;
  border-radius: 24rpx;
  background: #ffffff;
  color: #243447;
  font-size: 29rpx;
  font-weight: 700;
}

.form-input {
  height: 86rpx;
  padding: 0 24rpx;
  line-height: 86rpx;
}

.form-textarea {
  min-height: 150rpx;
  padding: 22rpx 24rpx;
  line-height: 1.55;
}

.double-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}
