.profile-card {
  display: grid;
  grid-template-columns: 118rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
}

.avatar-img {
  width: 118rpx;
  height: 118rpx;
  border-radius: 30rpx;
}

.profile-main {
  min-width: 0;
}

.profile-main .subtitle {
  display: block;
  margin-top: 6rpx;
}

.profile-name {
  display: block;
  margin-bottom: 8rpx;
  color: #243447;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.3;
}

.qr-button {
  grid-column: 1 / 3;
  height: 84rpx;
  margin-top: 10rpx;
  border-radius: 24rpx;
  background: #87c99f;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 84rpx;
  box-shadow: 0 12rpx 24rpx rgba(135, 201, 159, 0.22);
}

.menu-card {
  padding: 6rpx 28rpx 2rpx;
  margin-top: 20rpx;
}

.menu-row {
  min-height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  border-bottom: 1rpx solid #ece7df;
}

.menu-row:last-child {
  border-bottom: 0;
}

.menu-main {
  flex: 1 1 auto;
  min-width: 0;
}

.menu-title,
.menu-desc,
.binding-status,
.binding-code,
.setting-label,
.setting-desc {
  display: block;
}

.menu-title {
  color: #243447;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.35;
}

.menu-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.menu-arrow {
  flex: 0 0 auto;
  color: #b0a89b;
  font-size: 42rpx;
  line-height: 1;
}

.qr-modal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 22rpx;
  text-align: center;
}

.binding-status {
  color: #4d8d64;
  font-size: 26rpx;
  font-weight: 700;
}

.binding-code {
  padding: 14rpx 24rpx;
  border-radius: 18rpx;
  background: #edf8f1;
  color: #243447;
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.binding-qr-image,
.binding-qr-placeholder {
  width: 440rpx;
  height: 440rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.binding-qr-image {
  border: 2rpx solid #ece7df;
}

.binding-qr-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 26rpx;
  font-weight: 700;
}

.binding-actions {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  padding-top: 6rpx;
}

.half-btn {
  width: 100%;
}

.settings-modal {
  max-height: 90vh;
}

.setting-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-bottom: 1rpx solid #ece7df;
}

.setting-row > view {
  min-width: 0;
}

.setting-label {
  color: #243447;
  font-size: 30rpx;
  font-weight: 800;
}

.setting-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
  overflow-wrap: anywhere;
}

.picker-pill {
  min-width: 118rpx;
  height: 62rpx;
  border-radius: 20rpx;
  background: #fff3ea;
  color: #cb7c48;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 62rpx;
  text-align: center;
}

.setting-block {
  padding: 24rpx 0;
}

.logout-btn {
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 14rpx 0 18rpx;
  border: 2rpx solid #f1d0c8;
  border-radius: 24rpx;
  background: #fff6f4;
  color: #d95745;
  font-size: 30rpx;
  font-weight: 800;
}
