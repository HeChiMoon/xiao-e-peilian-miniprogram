.profile-card {
  display: grid;
  grid-template-columns: 118rpx 1fr;
  gap: 20rpx;
  align-items: center;
  padding: 28rpx;
  border-radius: 30rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(220, 215, 205, 0.62);
}

.avatar-img {
  width: 118rpx;
  height: 118rpx;
  border-radius: 50%;
}

.profile-main {
  min-width: 0;
}

.profile-main .subtitle {
  display: block;
}

.profile-name {
  display: block;
  margin-bottom: 8rpx;
  color: #3F3F3F;
  font-size: 36rpx;
  font-weight: 900;
}

.qr-button {
  grid-column: 1 / 3;
  height: 74rpx;
  border-radius: 37rpx;
  background: #88C9A1;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 74rpx;
}

.profile-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 26rpx;
}

.mini-card {
  min-height: 132rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.82);
}

.mini-card.wide {
  grid-column: 1 / 3;
}

.mini-label,
.mini-value {
  display: block;
}

.mini-label {
  color: #6B6B6B;
  font-size: 24rpx;
}

.mini-value {
  margin-top: 12rpx;
  color: #3F3F3F;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.3;
}

.mini-value.small {
  font-size: 28rpx;
  overflow-wrap: anywhere;
}

.menu-card {
  padding: 0 28rpx;
  margin-top: 26rpx;
}

.menu-row {
  min-height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-bottom: 1rpx solid #E8E6E1;
  color: #3F3F3F;
  font-size: 30rpx;
  font-weight: 800;
}

.menu-row text:first-child {
  flex: 0 0 auto;
}

.menu-row text:last-child {
  flex: 1 1 auto;
  min-width: 0;
  max-width: 58%;
  color: #6B6B6B;
  font-size: 24rpx;
  line-height: 1.2;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-row:last-child {
  border-bottom: 0;
}

.qr-modal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 22rpx;
  text-align: center;
}

.binding-status,
.binding-code {
  display: block;
}

.binding-status {
  color: #4F9A68;
  font-size: 26rpx;
  font-weight: 900;
}

.binding-code {
  padding: 14rpx 24rpx;
  border-radius: 18rpx;
  background: #F0F9F4;
  color: #3F3F3F;
  font-size: 32rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.binding-qr-image,
.binding-qr-placeholder {
  width: 440rpx;
  height: 440rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
}

.binding-qr-image {
  border: 4rpx solid #E8E6E1;
}

.binding-qr-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6B6B6B;
  font-size: 26rpx;
  font-weight: 800;
}

.binding-actions {
  width: 100%;
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  padding: 8rpx 6rpx 0;
}

.half-btn {
  flex: 1 1 0;
  width: auto;
  min-width: 0;
  height: 88rpx;
  font-size: 30rpx;
}

.binding-actions .half-btn:first-child {
  flex: 1.08 1 0;
}

.binding-actions .half-btn:last-child {
  flex: 0.92 1 0;
}

.settings-modal {
  max-height: 90vh;
}

.setting-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-bottom: 1rpx solid #E8E6E1;
}

.setting-row > view {
  min-width: 0;
}

.setting-label,
.setting-desc {
  display: block;
}

.setting-label {
  color: #3F3F3F;
  font-size: 30rpx;
  font-weight: 900;
}

.setting-desc {
  margin-top: 8rpx;
  color: #6B6B6B;
  font-size: 24rpx;
  line-height: 1.4;
  overflow-wrap: anywhere;
}

.picker-pill {
  min-width: 118rpx;
  height: 62rpx;
  border-radius: 31rpx;
  background: #FFF0E8;
  color: #F4A882;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 62rpx;
  text-align: center;
}

.setting-block {
  padding: 24rpx 0;
}

.logout-btn {
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 10rpx 0 20rpx;
  border: 3rpx solid #F2C7BE;
  border-radius: 43rpx;
  background: #FFF6F4;
  color: #D95745;
  font-size: 30rpx;
  font-weight: 900;
}
