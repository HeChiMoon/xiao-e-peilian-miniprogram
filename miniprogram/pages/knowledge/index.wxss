.knowledge-page {
  min-height: 100vh;
  padding: 28rpx 24rpx calc(44rpx + env(safe-area-inset-bottom));
  background: #f7f5f0;
  box-sizing: border-box;
}

.knowledge-hero {
  padding: 30rpx 28rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef8f6 100%);
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  color: #21322e;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.28;
}

.hero-copy {
  display: block;
  margin-top: 14rpx;
  color: #66736f;
  font-size: 27rpx;
  line-height: 1.55;
}

.knowledge-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 24rpx;
}

.knowledge-card {
  padding: 24rpx;
}

.knowledge-head {
  display: grid;
  grid-template-columns: 116rpx minmax(0, 1fr);
  column-gap: 20rpx;
  align-items: start;
}

.knowledge-icon {
  width: 116rpx;
  height: 116rpx;
  border-radius: 28rpx;
  background: #f2f6f4;
}

.knowledge-copy {
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.knowledge-title {
  flex: 1;
  color: #25322f;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.recommend-pill {
  flex: none;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #eaf5f2;
  color: #2f7568;
  font-size: 22rpx;
  font-weight: 700;
}

.knowledge-desc,
.recommend-reason {
  display: block;
  margin-top: 10rpx;
  color: #6a7470;
  font-size: 26rpx;
  line-height: 1.55;
}

.recommend-reason {
  color: #42796f;
}

.point-list {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #fbf8f2;
}

.point-row {
  display: grid;
  grid-template-columns: 16rpx minmax(0, 1fr);
  column-gap: 14rpx;
  align-items: start;
  padding: 7rpx 0;
}

.point-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 15rpx;
  border-radius: 50%;
  background: #f0a371;
}

.point-text {
  color: #4b5955;
  font-size: 27rpx;
  line-height: 1.45;
}

.knowledge-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 104rpx;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f3f1ec;
  color: #66736f;
  font-size: 24rpx;
  line-height: 58rpx;
  box-sizing: border-box;
}

.action-btn::after,
.comment-submit::after {
  border: 0;
}

.action-btn.active {
  color: #d36f3e;
}

.action-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.72;
  transition: opacity 0.18s ease, filter 0.18s ease;
}

.action-btn.active .action-icon {
  opacity: 1;
  filter: sepia(1) saturate(2.2) hue-rotate(330deg) brightness(0.98);
}

.comment-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  background: rgba(32, 42, 39, 0.32);
}

.comment-sheet {
  width: 100%;
  max-height: 78vh;
  padding: 18rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.sheet-handle {
  width: 78rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #d8dedb;
}

.comment-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.comment-head-main {
  flex: 1;
  min-width: 0;
}

.comment-title {
  display: block;
  color: #25322f;
  font-size: 34rpx;
  font-weight: 800;
}

.comment-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #7a8581;
  font-size: 24rpx;
  line-height: 1.4;
}

.comment-close {
  flex: none;
  color: #2f7568;
  font-size: 26rpx;
  font-weight: 700;
}

.quick-comment-block {
  margin-top: 22rpx;
}

.sheet-label {
  color: #7a8581;
  font-size: 24rpx;
}

.quick-comment-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.quick-comment-pill {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f8f6;
  color: #356f66;
  font-size: 25rpx;
}

.comment-list {
  max-height: 42vh;
  margin-top: 18rpx;
}

.comment-empty {
  padding: 28rpx 0;
  color: #8a9490;
  font-size: 26rpx;
  text-align: center;
}

.comment-row {
  display: grid;
  grid-template-columns: 58rpx minmax(0, 1fr);
  gap: 14rpx;
  padding: 12rpx 0;
}

.comment-avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #eaf5f2;
  color: #2f7568;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
}

.comment-card {
  min-width: 0;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  background: #f7f5f0;
}

.comment-meta {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
}

.comment-author {
  color: #25322f;
  font-size: 25rpx;
  font-weight: 700;
}

.comment-time {
  color: #9aa39f;
  font-size: 23rpx;
}

.comment-content {
  display: block;
  margin-top: 6rpx;
  color: #4b5955;
  font-size: 26rpx;
  line-height: 1.45;
}

.comment-editor {
  margin-top: 18rpx;
}

.comment-input-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 128rpx;
  gap: 14rpx;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.comment-input {
  min-width: 0;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #f3f1ec;
  color: #25322f;
  font-size: 27rpx;
  box-sizing: border-box;
}

.comment-placeholder {
  color: #a2aaa7;
}

.comment-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  min-width: 0;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #2f7568;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1;
  box-sizing: border-box;
}
