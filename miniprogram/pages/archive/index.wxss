.archive-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.archive-hero {
  display: grid;
  grid-template-columns: 118rpx minmax(0, 1fr);
  gap: 20rpx;
  align-items: center;
  background: linear-gradient(180deg, #ffffff, #fcfaf6);
}

.archive-avatar {
  width: 118rpx;
  height: 118rpx;
  border-radius: 30rpx;
}

.archive-copy {
  min-width: 0;
}

.info-card {
  padding: 4rpx 30rpx;
}

.info-row {
  min-height: 94rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid #ece7df;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-row text:first-child {
  color: #667085;
  font-size: 27rpx;
  font-weight: 700;
}

.info-row text:last-child {
  max-width: 58%;
  color: #243447;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
  text-align: right;
  overflow-wrap: anywhere;
}

.pose-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pose-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.history-btn {
  width: 132rpx;
  height: 72rpx;
  font-size: 27rpx;
}

.pose-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.pose-item {
  min-height: 110rpx;
  padding: 18rpx 14rpx;
  border-radius: 20rpx;
  background: #f7f4ee;
}

.pose-item text {
  display: block;
}

.pose-item text:first-child {
  color: #667085;
  font-size: 23rpx;
}

.pose-item text:last-child {
  margin-top: 12rpx;
  color: #243447;
  font-size: 28rpx;
  font-weight: 800;
  overflow-wrap: anywhere;
}

.pose-suggestion {
  display: block;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.58;
}

.archive-warning {
  font-size: 28rpx;
}

@media (max-width: 360px) {
  .pose-grid {
    grid-template-columns: 1fr;
  }
}
