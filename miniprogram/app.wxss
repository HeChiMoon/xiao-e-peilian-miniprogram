page {
  min-height: 100%;
  background: #F7F5F0;
  color: #3F3F3F;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 30rpx;
}

view,
text,
scroll-view,
swiper,
button,
input,
textarea {
  box-sizing: border-box;
}

text {
  overflow-wrap: break-word;
}

image {
  display: block;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font-size: inherit;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(140rpx + env(safe-area-inset-bottom));
  background: #F7F5F0;
}

.page.no-tab {
  padding-bottom: calc(54rpx + env(safe-area-inset-bottom));
}

.content {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.hero-title {
  color: #3F3F3F;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.25;
}

.subtitle {
  color: #6B6B6B;
  font-size: 28rpx;
  line-height: 1.55;
}

.card {
  padding: 32rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(220, 215, 205, 0.62);
}

.card.green {
  background: #F0F9F4;
}

.card.peach {
  background: #FFF0E8;
}

.card-title {
  display: block;
  color: #3F3F3F;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.25;
}

.card-copy {
  display: block;
  margin-top: 14rpx;
  color: #6B6B6B;
  font-size: 28rpx;
  line-height: 1.55;
}

.primary-btn,
.success-btn,
.outline-btn,
.dark-btn {
  height: 92rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 800;
}

.primary-btn {
  background: #F4A882;
  color: #FFFFFF;
}

.success-btn {
  background: #88C9A1;
  color: #FFFFFF;
}

.outline-btn {
  border: 3rpx solid #F4A882;
  background: #FFFFFF;
  color: #F4A882;
}

.dark-btn {
  background: #3F3F3F;
  color: #FFFFFF;
}

.option-btn {
  min-height: 86rpx;
  padding: 20rpx 26rpx;
  border: 3rpx solid #E8E6E1;
  border-radius: 28rpx;
  background: #FFFFFF;
  color: #3F3F3F;
  font-size: 28rpx;
  line-height: 1.45;
  text-align: left;
}

.option-btn.selected {
  border-color: #F4A882;
  background: #FFF8F0;
  color: #C66F3C;
  font-weight: 900;
}

.top-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.round-img {
  width: 118rpx;
  height: 118rpx;
  border-radius: 50%;
  object-fit: cover;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx;
  background: rgba(0, 0, 0, 0.55);
}

.modal-card {
  width: 100%;
  max-height: 82vh;
  overflow: hidden;
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.22);
}

.modal-body {
  padding: 34rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: rgba(136, 201, 161, 0.14);
  color: #4F9A68;
  font-size: 24rpx;
  font-weight: 800;
}

.warning-box {
  padding: 24rpx;
  border-left: 8rpx solid #FFA726;
  border-radius: 20rpx;
  background: #FFF8E1;
  color: #8A4A00;
  font-size: 28rpx;
  line-height: 1.6;
}
