page {
  min-height: 100%;
  background: #f6f3ec;
  color: #374151;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 30rpx;
}

view,
text,
scroll-view,
swiper,
button,
input,
textarea {
  box-sizing: border-box;
}

text {
  overflow-wrap: break-word;
}

image {
  display: block;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font-size: inherit;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(144rpx + env(safe-area-inset-bottom));
  background: #f6f3ec;
}

.page.no-tab {
  padding-bottom: calc(54rpx + env(safe-area-inset-bottom));
}

.content {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.hero-title {
  color: #243447;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.3;
}

.subtitle {
  color: #667085;
  font-size: 28rpx;
  line-height: 1.65;
}

.card {
  padding: 32rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(180, 172, 157, 0.18);
}

.card.green {
  background: #edf8f1;
}

.card.peach {
  background: #fff3ea;
}

.card-title {
  display: block;
  color: #243447;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.32;
}

.card-copy {
  display: block;
  margin-top: 14rpx;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.6;
}

.section-kicker {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  margin-bottom: 12rpx;
  padding: 0 16rpx;
  border-radius: 21rpx;
  background: #f5efe5;
  color: #8e7157;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.green-kicker {
  background: rgba(135, 201, 159, 0.18);
  color: #4d8d64;
}

.peach-kicker {
  background: rgba(240, 161, 116, 0.16);
  color: #cb7c48;
}

.sky-kicker {
  background: rgba(117, 176, 209, 0.14);
  color: #4d7f9a;
}

.primary-btn,
.success-btn,
.outline-btn,
.dark-btn {
  height: 92rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 31rpx;
  font-weight: 800;
}

.primary-btn {
  background: #f0a174;
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(240, 161, 116, 0.24);
}

.success-btn {
  background: #87c99f;
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(135, 201, 159, 0.24);
}

.outline-btn {
  border: 2rpx solid #f0a174;
  background: #ffffff;
  color: #d57d49;
}

.dark-btn {
  background: #3F3F3F;
  color: #FFFFFF;
}

.option-btn {
  min-height: 86rpx;
  padding: 20rpx 26rpx;
  border: 3rpx solid #E8E6E1;
  border-radius: 28rpx;
  background: #FFFFFF;
  color: #3F3F3F;
  font-size: 28rpx;
  line-height: 1.45;
  text-align: left;
}

.option-btn.selected {
  border-color: #F4A882;
  background: #FFF8F0;
  color: #C66F3C;
  font-weight: 900;
}

.top-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.round-img {
  width: 118rpx;
  height: 118rpx;
  border-radius: 50%;
  object-fit: cover;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx;
  background: rgba(0, 0, 0, 0.55);
}

.modal-card {
  width: 100%;
  max-height: 82vh;
  overflow: hidden;
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.22);
}

.modal-body {
  padding: 34rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: rgba(135, 201, 159, 0.16);
  color: #4d8d64;
  font-size: 23rpx;
  font-weight: 700;
}

.warning-box {
  padding: 24rpx;
  border-left: 8rpx solid #FFA726;
  border-radius: 20rpx;
  background: #FFF8E1;
  color: #8A4A00;
  font-size: 28rpx;
  line-height: 1.6;
}
